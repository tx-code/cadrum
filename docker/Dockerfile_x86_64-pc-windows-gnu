# Prebuild OCCT for x86_64-pc-windows-gnullvm using the llvm-mingw toolchain.
#
# Why llvm-mingw (not Debian apt mingw-w64):
# - UCRT-bound by default, matching Rust's self-contained mingw (1.80+), so
#   cadrum prebuilt and downstream Rust agree on `FILE*` / CRT semantics.
# - Ships libc++ and libunwind as static archives ready to absorb with
#   `-static`, so the final exe has no libstdc++-6.dll / libgcc_s_seh-1.dll /
#   libwinpthread-1.dll / libc++.dll / libunwind.dll runtime dependency.
# - Same toolchain distribution used by upstream Rust for its windows-gnu
#   self-contained component, so unwind model (SEH) and ABI stay aligned.
FROM mstorsjo/llvm-mingw:latest

# Base image ships cmake/make/git but not rustup. Install a minimal Rust.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH=/root/.cargo/bin:/opt/llvm-mingw/bin:$PATH

# control cc crate and cargo command
#
# llvm-mingw's default `x86_64-w64-mingw32-clang` targets UCRT; the `-uwp`
# variant targets the Windows Store subset and is out of scope here. `ar` is
# the Binutils-style wrapper that llvm-mingw ships alongside clang.
ENV CC=x86_64-w64-mingw32-clang
ENV CXX=x86_64-w64-mingw32-clang++
ENV AR=x86_64-w64-mingw32-ar
ENV CARGO_BUILD_TARGET=x86_64-pc-windows-gnullvm

# linker: rustc defaults to `x86_64-w64-mingw32-gcc` for this target; point it
# at the llvm-mingw clang driver instead so final-link flags (-static, etc.)
# are interpreted by the same driver that compiled the C++ sources.
ENV CARGO_TARGET_X86_64_PC_WINDOWS_GNULLVM_LINKER=x86_64-w64-mingw32-clang

# link-cplusplus declares `#[link(name="stdc++")]` by default, but llvm-mingw
# ships the C++ stdlib as `libc++.a` (no libstdc++ alias). Remap the library
# name via the documented CXXSTDLIB_<target> env var so link-cplusplus emits
# `-lc++` instead. Dynamic (not static=) so rustc defers the resolution to
# final link, where `cargo:rustc-link-arg=-static` from build.rs tells the
# clang driver to absorb libc++.a / libunwind.a statically alongside libgcc /
# libwinpthread. Downstream users pick up the same behavior automatically
# because `-static` is emitted by cadrum's own build.rs.
ENV CXXSTDLIB_x86_64_pc_windows_gnullvm=c++

# add cargo target
RUN rustup target add ${CARGO_BUILD_TARGET}

# copy source and build OCCT prebuilt
WORKDIR /src
COPY . /src
